# Copia como .env.local con tus credenciales de Supabase
# Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui
VITE_VAPID_PUBLIC_KEY=tu-vapid-public-key-aqui

# Supabase Edge Function secrets (no los expongas en Vite/Vercel como VITE_*)
# VAPID_PUBLIC_KEY=tu-vapid-public-key-aqui
# VAPID_PRIVATE_KEY=tu-vapid-private-key-aqui
# VAPID_SUBJECT=mailto:hola@latido.ch
# PUSH_WEBHOOK_SECRET=un-string-largo-y-secreto

# Delayed message emails via the normal Nominalia mailbox included with the domain
# SMTP_HOSTNAME=authsmtp.securemail.pro
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USERNAME=notificaciones@latido.ch
# SMTP_PASSWORD=password-del-buzon
# SMTP_FROM=Latido <notificaciones@latido.ch>
# LATIDO_APP_URL=https://www.latido.ch
# EMAIL_CRON_SECRET=otro-string-largo-y-secreto
# EMAIL_MAX_BATCH=25

# Eventfrog
EVENTFROG_API_KEY=tu-public-api-key-aqui
# Opcional: solo si tienes la clave del widget iframe de Eventfrog.
VITE_EVENTFROG_EMBED_KEY=tu-embed-key-aqui
