# Copia como .env.local con tus credenciales de Supabase
# Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Eventfrog
EVENTFROG_API_KEY=tu-public-api-key-aqui
# Opcional: solo si tienes la clave del widget iframe de Eventfrog.
VITE_EVENTFROG_EMBED_KEY=tu-embed-key-aqui
